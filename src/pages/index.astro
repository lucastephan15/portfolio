---
import Layout from "../layouts/Layout.astro";
import { amadeusProjects, personalProjects } from "../data/projects";

const groups = [
  {
    label: "Amadeus AI",
    note: "Trabalho profissional — agentes, automações e dados em produção.",
    items: amadeusProjects,
  },
  {
    label: "Pessoal & Pesquisa",
    note: "Projetos próprios, apps e artigos acadêmicos.",
    items: personalProjects,
  },
];

const nav = [
  { label: "Sobre", href: "#sobre" },
  { label: "Trabalhos", href: "#trabalhos" },
  { label: "Contato", href: "#contato" },
];
---

<Layout>
  <!-- ── Top bar ─────────────────────────────────────────────── -->
  <header
    class="mx-auto flex max-w-6xl items-center justify-between px-6 py-6 md:px-10"
  >
    <a href="#" class="font-display text-lg font-semibold tracking-tight">
      Luca Stephan
    </a>
    <nav class="flex gap-6 text-sm text-muted">
      {
        nav.map((item) => (
          <a href={item.href} class="transition-colors hover:text-accent">
            {item.label}
          </a>
        ))
      }
    </nav>
  </header>

  <!-- ── Hero ────────────────────────────────────────────────── -->
  <section
    class="mx-auto grid max-w-6xl gap-10 px-6 pb-24 pt-16 md:grid-cols-12 md:px-10 md:pt-24"
  >
    <div class="md:col-span-8">
      <p class="mb-6 font-sans text-sm uppercase tracking-[0.2em] text-accent">
        Builder · AI Engineer · Pouso Alegre, BR
      </p>
      <h1
        class="font-display text-5xl font-light leading-[1.05] tracking-tight md:text-7xl"
      >
        Construo coisas na fronteira entre
        <em class="italic text-accent">software, dados</em> e
        <em class="italic">inteligência</em>.
      </h1>
      <p class="mt-8 max-w-xl text-lg leading-relaxed text-muted">
        Apps que resolvem problemas reais, ferramentas que eu mesmo queria
        usar e pesquisa sobre como modelos de linguagem realmente se comportam.
        Programador autodidata com formação em administração — gosto de
        entender o sistema inteiro, não só o código.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="#trabalhos"
          class="rounded-full bg-ink px-6 py-3 text-sm text-paper transition-transform hover:-translate-y-0.5"
        >
          Ver trabalhos
        </a>
        <a
          href="#contato"
          class="rounded-full border border-line px-6 py-3 text-sm transition-colors hover:border-accent hover:text-accent"
        >
          Entrar em contato
        </a>
      </div>
    </div>

    <!-- Hero visual: Pouso Alegre em pixel art (Pixel Lab) -->
    <div class="md:col-span-4 md:pt-2">
      <figure>
        <div class="overflow-hidden rounded-2xl border border-line shadow-sm">
          <img
            src="/images/pouso-alegre-pixel.png"
            alt="Pouso Alegre em pixel art — a praça da catedral"
            width="256"
            height="256"
            loading="eager"
            class="h-full w-full"
            style="image-rendering: pixelated;"
          />
        </div>
        <figcaption
          class="mt-3 text-center font-display text-sm italic text-muted"
        >
          Pouso Alegre, MG — de onde eu construo.
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- ── Sobre ───────────────────────────────────────────────── -->
  <section id="sobre" class="border-t border-line bg-paper-deep/40 py-20 md:py-28">
    <div class="mx-auto grid max-w-6xl gap-10 px-6 md:grid-cols-12 md:px-10">
      <div class="md:col-span-4">
        <span class="font-display text-sm text-accent">01 — Sobre</span>
      </div>
      <div class="md:col-span-8">
        <p class="font-display text-2xl font-light leading-snug md:text-3xl">
          Venho da administração de empresas — FGV EAESP e HEC Paris — e virei
          programador por conta própria. Hoje trabalho com IA aplicada, do dado
          cru ao produto que alguém usa. Essa lente dupla, negócio e código, é o
          que trago pra cada projeto.
        </p>

        <div class="mt-10 grid gap-8 border-t border-line pt-8 sm:grid-cols-2">
          <div>
            <h3 class="mb-4 text-xs uppercase tracking-[0.2em] text-accent">
              Formação
            </h3>
            <ul class="space-y-4 text-sm">
              <li>
                <span class="block font-medium">HEC Paris</span>
                <span class="text-muted">
                  Bachelor of Business Administration (BBA) · 2023–
                </span>
              </li>
              <li>
                <span class="block font-medium">FGV EAESP</span>
                <span class="text-muted">
                  Administração de Empresas · São Paulo
                </span>
              </li>
            </ul>
          </div>
          <div>
            <h3 class="mb-4 text-xs uppercase tracking-[0.2em] text-accent">
              Reconhecimentos
            </h3>
            <ul class="space-y-4 text-sm">
              <li>
                <span class="block font-medium">
                  Quadro de Honra · FGV EAESP
                </span>
                <span class="text-muted">
                  Entre os 10 melhores alunos do semestre — 3º lugar (2020.2) e
                  9º lugar (2021.2)
                </span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Trabalhos ───────────────────────────────────────────── -->
  <section id="trabalhos" class="mx-auto max-w-6xl px-6 py-20 md:px-10 md:py-28">
    <div
      class="mb-12 flex items-baseline justify-between border-b border-line pb-6"
    >
      <h2 class="font-display text-3xl font-light md:text-4xl">
        Trabalhos selecionados
      </h2>
      <span class="font-display text-sm text-accent">02 — Trabalhos</span>
    </div>

    {
      groups.map((g, gi) => {
        // numeração de sumário contínua entre os grupos
        const offset = groups
          .slice(0, gi)
          .reduce((n, prev) => n + prev.items.length, 0);
        return (
          <div class={gi > 0 ? "mt-20" : ""}>
            <div class="mb-6 flex flex-wrap items-baseline justify-between gap-2">
              <h3 class="font-display text-xl italic text-accent">{g.label}</h3>
              <p class="text-sm text-muted">{g.note}</p>
            </div>
            <ul class="divide-y divide-line border-t border-line">
              {g.items.map((p, i) => (
                <li>
                  <a
                    href={p.href ?? "#"}
                    class="group grid gap-4 py-8 transition-colors hover:bg-paper-deep/40 md:grid-cols-12 md:gap-6 md:px-4"
                  >
                    <div class="flex items-baseline gap-4 md:col-span-1">
                      <span class="font-display text-sm text-muted">
                        {String(offset + i + 1).padStart(2, "0")}
                      </span>
                    </div>
                    <div class="md:col-span-7">
                      <h4 class="font-display text-2xl font-light tracking-tight transition-colors group-hover:text-accent md:text-3xl">
                        {p.title}
                      </h4>
                      <p class="mt-2 max-w-xl leading-relaxed text-muted">
                        {p.blurb}
                      </p>
                      <div class="mt-3 flex flex-wrap gap-2">
                        {p.tags.map((t) => (
                          <span class="rounded-full border border-line px-3 py-1 text-xs text-muted">
                            {t}
                          </span>
                        ))}
                      </div>
                    </div>
                    <div class="text-sm text-muted md:col-span-4 md:text-right">
                      <span class="block">{p.kind}</span>
                      <span class="block">{p.year}</span>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        );
      })
    }
  </section>

  <!-- ── Contato ─────────────────────────────────────────────── -->
  <section id="contato" class="border-t border-line bg-ink py-20 text-paper md:py-28">
    <div class="mx-auto max-w-6xl px-6 md:px-10">
      <span class="font-display text-sm text-paper/60">03 — Contato</span>
      <h2
        class="mt-4 max-w-2xl font-display text-4xl font-light leading-tight md:text-6xl"
      >
        Vamos construir algo juntos?
      </h2>
      <div class="mt-10 flex flex-wrap gap-6 text-lg">
        <a
          href="mailto:lucastephan8@gmail.com"
          class="underline decoration-paper/30 underline-offset-8 transition-colors hover:decoration-paper"
        >
          lucastephan8@gmail.com
        </a>
        <a
          href="https://github.com/lucastephan15"
          class="underline decoration-paper/30 underline-offset-8 transition-colors hover:decoration-paper"
        >
          GitHub
        </a>
      </div>
      <p class="mt-16 text-sm text-paper/50">
        © {new Date().getFullYear()} Luca Stephan — feito com Astro.
      </p>
    </div>
  </section>
</Layout>
