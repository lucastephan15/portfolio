<script>
  // Carrossel "Um pouco mais sobre mim" — leve, sem dependências.
  function initCarousel(root: HTMLElement) {
    const track = root.querySelector<HTMLElement>("[data-track]");
    const slides = track ? Array.from(track.children) as HTMLElement[] : [];
    const dots = Array.from(root.querySelectorAll<HTMLElement>("[data-dot]"));
    const prev = root.querySelector<HTMLElement>("[data-prev]");
    const next = root.querySelector<HTMLElement>("[data-next]");
    if (!track || slides.length === 0) return;

    let index = 0;
    const total = slides.length;
    const interval = Number(root.dataset.interval) || 0;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let timer: number | undefined;

    function render() {
      track!.style.transform = `translateX(-${index * 100}%)`;
      dots.forEach((d, i) => {
        const on = i === index;
        d.style.width = on ? "1.5rem" : "0.5rem";
        d.classList.toggle("bg-paper", on);
        d.classList.toggle("bg-paper/50", !on);
        d.setAttribute("aria-current", on ? "true" : "false");
      });
    }
    function go(i: number) {
      index = (i + total) % total;
      render();
    }
    function play() {
      if (!interval || reduce) return;
      stop();
      timer = window.setInterval(() => go(index + 1), interval);
    }
    function stop() {
      if (timer) window.clearInterval(timer);
    }

    next?.addEventListener("click", () => { go(index + 1); play(); });
    prev?.addEventListener("click", () => { go(index - 1); play(); });
    dots.forEach((d, i) => d.addEventListener("click", () => { go(i); play(); }));

    root.addEventListener("mouseenter", stop);
    root.addEventListener("mouseleave", play);
    root.addEventListener("focusin", stop);
    root.addEventListener("focusout", play);

    // Teclado (quando o carrossel está em foco)
    root.tabIndex = 0;
    root.addEventListener("keydown", (e) => {
      if (e.key === "ArrowRight") { go(index + 1); play(); }
      if (e.key === "ArrowLeft") { go(index - 1); play(); }
    });

    // Swipe / arraste
    let startX = 0, dragging = false;
    root.addEventListener("pointerdown", (e) => { dragging = true; startX = e.clientX; stop(); });
    root.addEventListener("pointerup", (e) => {
      if (!dragging) return;
      dragging = false;
      const dx = e.clientX - startX;
      if (Math.abs(dx) > 40) go(index + (dx < 0 ? 1 : -1));
      play();
    });

    // Transição suave (respeitando reduced-motion)
    track.style.transition = reduce ? "none" : "transform 500ms cubic-bezier(0.22,1,0.36,1)";
    render();
    play();
  }

  document.querySelectorAll<HTMLElement>("[data-carousel]").forEach(initCarousel);
</script>

<script>
  // Modal de cases — clona a fonte oculta correspondente ao slug.
  const modal = document.getElementById("case-modal");
  const body = document.getElementById("case-modal-body");
  const sources = document.getElementById("case-sources");

  if (modal && body && sources) {
    let lastFocus: HTMLElement | null = null;

    const open = (slug: string, trigger: HTMLElement) => {
      const src = sources.querySelector(`[data-modal="${slug}"]`);
      if (!src) return;
      lastFocus = trigger;
      body.innerHTML = src.innerHTML;
      body.scrollTop = 0;
      modal.classList.remove("hidden");
      modal.classList.add("flex");
      modal.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
      (modal.querySelector("[data-close]") as HTMLElement | null)?.focus();
    };

    const close = () => {
      modal.classList.add("hidden");
      modal.classList.remove("flex");
      modal.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      body.innerHTML = "";
      lastFocus?.focus();
    };

    document.querySelectorAll<HTMLElement>("[data-open]").forEach((el) => {
      el.addEventListener("click", () =>
        open(el.getAttribute("data-open") || "", el),
      );
    });
    modal.querySelector("[data-backdrop]")?.addEventListener("click", close);
    modal.querySelector("[data-close]")?.addEventListener("click", close);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !modal.classList.contains("hidden")) close();
    });
  }
</script>

<script>
  // Filtro de trabalhos por ferramenta (stack). Multi-seleção, semântica OU.
  const section = document.getElementById("trabalhos");
  if (section) {
    const chips = Array.from(section.querySelectorAll<HTMLElement>("[data-filter]"));
    const cards = Array.from(section.querySelectorAll<HTMLElement>("[data-card]"));
    const groups = Array.from(section.querySelectorAll<HTMLElement>("[data-group]"));
    const clears = Array.from(section.querySelectorAll<HTMLElement>("[data-filter-clear]"));
    const empty = section.querySelector<HTMLElement>("[data-empty]");
    const active = new Set<string>();

    const apply = () => {
      let anyVisible = false;
      cards.forEach((card) => {
        const tools = (card.getAttribute("data-tools") || "").split(" ");
        const show =
          active.size === 0 || [...active].some((a) => tools.includes(a));
        card.classList.toggle("hidden", !show);
        if (show) anyVisible = true;
      });
      groups.forEach((g) => {
        const hasVisible = !!g.querySelector("[data-card]:not(.hidden)");
        g.classList.toggle("hidden", !hasVisible);
      });
      chips.forEach((ch) =>
        ch.classList.toggle(
          "is-active",
          active.has(ch.getAttribute("data-filter") || ""),
        ),
      );
      clears.forEach((c) => ((c as HTMLButtonElement).hidden = active.size === 0));
      if (empty) empty.hidden = anyVisible;
    };

    chips.forEach((ch) =>
      ch.addEventListener("click", () => {
        const slug = ch.getAttribute("data-filter") || "";
        if (active.has(slug)) active.delete(slug);
        else active.add(slug);
        apply();
      }),
    );
    clears.forEach((c) =>
      c.addEventListener("click", () => {
        active.clear();
        apply();
      }),
    );
  }
</script>

<script>
  // Reveal dos passos do AI-Ready ao entrar na viewport (respeita reduced-motion).
  const steps = document.querySelector<HTMLElement>("[data-steps]");
  const reduceMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;
  if (steps && !reduceMotion && "IntersectionObserver" in window) {
    steps.classList.add("steps-anim");
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            steps.classList.add("is-in");
            io.disconnect();
          }
        });
      },
      { threshold: 0.25 },
    );
    io.observe(steps);
  }
</script>
