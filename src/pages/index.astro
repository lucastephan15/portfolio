---
import Layout from "../layouts/Layout.astro";
import { aboutSlides } from "../data/about";
import {
  cases,
  highlightCases,
  amadeusCompact,
  pessoalCases,
  TOOLS,
} from "../data/cases";
import { diagrams } from "../data/diagrams";
import ToolChips from "../components/ToolChips.astro";

// Ferramentas para a barra de filtro (todas que aparecem, mais usadas primeiro).
const toolCounts = new Map<string, number>();
for (const c of cases)
  for (const t of c.tools) toolCounts.set(t, (toolCounts.get(t) || 0) + 1);
const filterTools = [...toolCounts.entries()]
  .map(([slug, count]) => ({
    slug,
    count,
    name: TOOLS[slug]?.name,
    icon: TOOLS[slug]?.icon,
  }))
  .filter((t) => t.name)
  .sort((a, b) => b.count - a.count);

const nav = [
  { label: "Sobre", href: "#sobre" },
  { label: "Trabalhos", href: "#trabalhos" },
  { label: "AI-Ready", href: "#ai-ready" },
  { label: "Contato", href: "#contato" },
];
---

<Layout>
  <!-- ── Hero full-bleed: Pouso Alegre animada (Pixel Lab) ───── -->
  <section class="relative isolate flex min-h-[90vh] flex-col overflow-hidden">
    <!-- Fundo: cidade animada + quadro estático p/ reduced-motion -->
    <img
      src="/images/pouso-alegre-hero.webp"
      alt="Pouso Alegre em pixel art — a praça da catedral, animada"
      width="384"
      height="216"
      class="hero-anim absolute inset-0 -z-20 h-full w-full object-cover"
      style="image-rendering: pixelated;"
    />
    <img
      src="/images/pouso-alegre-hero-static.png"
      alt="Pouso Alegre em pixel art — a praça da catedral"
      width="384"
      height="216"
      class="hero-static absolute inset-0 -z-20 h-full w-full object-cover"
      style="image-rendering: pixelated;"
    />
    <!-- Scrim de legibilidade -->
    <div
      class="absolute inset-0 -z-10 bg-gradient-to-t from-ink/90 via-ink/45 to-ink/25"
    >
    </div>

    <!-- Top bar sobreposta -->
    <header
      class="mx-auto flex w-full max-w-6xl items-center justify-between px-6 py-6 md:px-10"
    >
      <a
        href="#"
        class="font-display text-lg font-semibold tracking-tight text-paper"
      >
        Luca Stephan
      </a>
      <nav class="flex gap-6 text-sm text-paper/80">
        {
          nav.map((item) => (
            <a href={item.href} class="transition-colors hover:text-paper">
              {item.label}
            </a>
          ))
        }
      </nav>
    </header>

    <!-- Conteúdo do hero, ancorado embaixo -->
    <div
      class="mx-auto flex w-full max-w-6xl flex-1 flex-col justify-end px-6 pb-20 pt-16 md:px-10"
    >
      <p class="mb-5 font-sans text-sm uppercase tracking-[0.2em] text-paper/90">
        AI Engineer · Automações · Pouso Alegre, BR
      </p>
      <h1
        class="max-w-3xl font-display text-5xl font-light leading-[1.05] tracking-tight text-paper md:text-7xl"
      >
        Construo <em class="italic text-accent-soft">sistemas de IA</em> e
        <em class="italic">automações</em> sob medida — do dado não estruturado
        ao produto final.
      </h1>
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="#trabalhos"
          class="rounded-full bg-paper px-6 py-3 text-sm text-ink transition-transform hover:-translate-y-0.5"
        >
          Ver trabalhos
        </a>
        <a
          href="#contato"
          class="rounded-full border border-paper/40 px-6 py-3 text-sm text-paper transition-colors hover:bg-paper/10"
        >
          Entrar em contato
        </a>
      </div>
    </div>
  </section>

  <!-- ── Sobre ───────────────────────────────────────────────── -->
  <section id="sobre" class="border-t border-line bg-paper-deep/40 py-20 md:py-28">
    <div class="mx-auto grid max-w-6xl gap-10 px-6 md:grid-cols-12 md:px-10">
      <div class="md:col-span-4">
        <span class="font-display text-sm text-accent">01 — Sobre</span>
        <img
          src="/images/wizard-luca.webp"
          alt="Luca como um mago pixel art, meditando"
          width="256"
          height="256"
          loading="lazy"
          class="mt-2 w-80 md:-ml-20 md:-mt-4 md:w-[140%] md:max-w-none"
          style="image-rendering: pixelated;"
        />
      </div>
      <div class="md:col-span-8">
        <p class="font-display text-2xl font-light leading-snug md:text-3xl">
          Venho da administração de empresas — FGV EAESP e HEC Paris —, com
          formação voltada a empreendedorismo, programação e estatística.
          Construo sistemas de IA, agentes e automações sob medida:
          independentemente de como a empresa organiza ou armazena seus dados.
        </p>
        <p class="mt-6 max-w-2xl leading-relaxed text-muted">
          Trabalho como generalista — domino negócio e código, então conduzo um
          projeto complexo da concepção à entrega ponta a ponta, sozinho ou ao
          lado de profissionais com a mesma abordagem e ritmo de trabalho. Na
          prática, isso vira soluções altamente personalizadas, entregues em
          prazos curtos e sem fricção de repasse. Em paralelo, curso pós em
          Machine Learning Engineering, consolidando a base técnica desse
          trabalho.
        </p>

        <div class="mt-10 grid gap-8 border-t border-line pt-8 sm:grid-cols-2">
          <div>
            <h3 class="mb-4 text-xs uppercase tracking-[0.2em] text-accent">
              Formação
            </h3>
            <ul class="space-y-4 text-sm">
              <li>
                <span class="block font-medium">
                  Pós · Machine Learning Engineering
                </span>
                <span class="text-muted">FIAP · 2025–2027</span>
              </li>
              <li>
                <span class="block font-medium">HEC Paris</span>
                <span class="text-muted">Intercâmbio · 2023–2024</span>
              </li>
              <li>
                <span class="block font-medium">FGV EAESP</span>
                <span class="text-muted">
                  Administração de Empresas · 2020–2025
                </span>
              </li>
            </ul>
          </div>
          <div>
            <h3 class="mb-4 text-xs uppercase tracking-[0.2em] text-accent">
              Reconhecimentos
            </h3>
            <ul class="space-y-4 text-sm">
              <li>
                <span class="block font-medium">
                  Quadro de Honra · FGV EAESP
                </span>
                <span class="text-muted">
                  Entre os 10 melhores alunos do semestre — 3º lugar (2020.2) e
                  9º lugar (2021.2)
                </span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Trabalhos ───────────────────────────────────────────── -->
  <section id="trabalhos" class="mx-auto max-w-6xl px-6 py-20 md:px-10 md:py-28">
    <div
      class="mb-10 flex items-baseline justify-between border-b border-line pb-6"
    >
      <h2 class="font-display text-3xl font-light md:text-4xl">
        Trabalhos selecionados
      </h2>
      <span class="font-display text-sm text-accent">02 — Trabalhos</span>
    </div>

    <!-- Filtro por ferramenta -->
    <div class="mb-10" data-filterbar>
      <div class="flex flex-wrap items-center gap-2">
        <span class="mr-1 text-xs uppercase tracking-[0.18em] text-muted">
          Filtrar por stack
        </span>
        {
          filterTools.map((t) => (
            <button
              type="button"
              data-filter={t.slug}
              class="filter-chip inline-flex items-center gap-1.5 rounded-full border border-line bg-paper px-2.5 py-1 text-xs text-muted transition hover:border-accent/50"
            >
              {t.icon && (
                <img
                  src={`/images/icons/${t.icon}.svg`}
                  alt=""
                  width="14"
                  height="14"
                  class="h-3.5 w-3.5"
                />
              )}
              {t.name}
            </button>
          ))
        }
        <button
          type="button"
          data-filter-clear
          hidden
          class="ml-1 rounded-full px-2.5 py-1 text-xs text-accent underline underline-offset-2"
        >
          Limpar
        </button>
      </div>
    </div>

    <!-- Destaques -->
    <div data-group>
      <p class="mb-6 text-sm uppercase tracking-[0.2em] text-accent">
        Em destaque
      </p>
      <div class="grid gap-5 md:grid-cols-2">
        {
          highlightCases.map((c) => (
            <button
              type="button"
              data-open={c.slug}
              data-card
              data-tools={c.tools.join(" ")}
              class="group flex h-full flex-col items-start rounded-xl border border-line bg-paper-deep/40 p-6 text-left transition hover:border-accent/40 hover:bg-paper-deep md:p-8"
            >
              <span class="text-xs uppercase tracking-[0.18em] text-accent">
                {c.category}
              </span>
              <h3 class="mt-3 font-display text-2xl font-light leading-snug tracking-tight transition-colors group-hover:text-accent">
                {c.title}
              </h3>
              <p class="mt-3 leading-relaxed text-muted">{c.summary}</p>
              {c.impact && <p class="mt-3 text-sm text-ink/75">↳ {c.impact}</p>}
              <div class="mt-5">
                <ToolChips tools={c.tools} />
              </div>
              <span class="mt-6 inline-flex items-center gap-1.5 text-sm font-medium text-accent">
                Ver arquitetura
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-0.5"><path d="m9 18 6-6-6-6" /></svg>
              </span>
            </button>
          ))
        }
      </div>
    </div>

    <!-- Amadeus — grade compacta -->
    <div data-group class="mt-16">
      <div class="mb-6 flex flex-wrap items-baseline justify-between gap-2">
        <h3 class="font-display text-xl italic text-accent">Amadeus AI</h3>
        <p class="text-sm text-muted">
          Mais automações, agentes e dados em produção.
        </p>
      </div>
      <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          amadeusCompact.map((c) => (
            <li class="h-full" data-card data-tools={c.tools.join(" ")}>
              <button
                type="button"
                data-open={c.slug}
                class="group flex h-full w-full flex-col items-start rounded-lg border border-line p-5 text-left transition hover:border-accent/40 hover:bg-paper-deep/40"
              >
                <span class="text-[11px] uppercase tracking-wider text-accent">
                  {c.category}
                </span>
                <h4 class="mt-2 font-display text-lg leading-snug transition-colors group-hover:text-accent">
                  {c.title}
                </h4>
                <p class="mt-2 text-sm leading-relaxed text-muted">
                  {c.summary}
                </p>
                <div class="mt-4">
                  <ToolChips tools={c.tools} />
                </div>
              </button>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Pessoal & pesquisa -->
    <div data-group class="mt-16">
      <div class="mb-6 flex flex-wrap items-baseline justify-between gap-2">
        <h3 class="font-display text-xl italic text-accent">
          Pessoal & Pesquisa
        </h3>
        <p class="text-sm text-muted">Projetos próprios, apps e artigos.</p>
      </div>
      <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          pessoalCases.map((c) => (
            <li class="h-full" data-card data-tools={c.tools.join(" ")}>
              <button
                type="button"
                data-open={c.slug}
                class="group flex h-full w-full flex-col items-start rounded-lg border border-line p-5 text-left transition hover:border-accent/40 hover:bg-paper-deep/40"
              >
                <span class="text-[11px] uppercase tracking-wider text-accent">
                  {c.category}
                </span>
                <h4 class="mt-2 font-display text-lg leading-snug transition-colors group-hover:text-accent">
                  {c.title}
                </h4>
                <p class="mt-2 text-sm leading-relaxed text-muted">
                  {c.summary}
                </p>
                <div class="mt-4">
                  <ToolChips tools={c.tools} />
                </div>
              </button>
            </li>
          ))
        }
      </ul>
    </div>

    <p data-empty hidden class="mt-10 text-sm text-muted">
      Nenhum trabalho com esse filtro.{" "}
      <button
        type="button"
        data-filter-clear
        class="text-accent underline underline-offset-2"
      >
        Limpar filtros
      </button>
    </p>
  </section>

  <!-- ── AI-Ready (serviço) ──────────────────────────────────── -->
  <section
    id="ai-ready"
    class="relative isolate overflow-hidden border-t border-line bg-ink py-20 text-paper md:py-28"
  >
    <!-- Fundo: sala de controle pixel art + scrim de legibilidade -->
    <img
      src="/images/ai-ready-bg.webp"
      alt=""
      aria-hidden="true"
      width="344"
      height="192"
      loading="lazy"
      class="absolute inset-0 -z-20 h-full w-full object-cover opacity-90"
      style="image-rendering: pixelated;"
    />
    <div
      class="absolute inset-0 -z-10 bg-gradient-to-r from-ink/95 via-ink/85 to-ink/60"
    >
    </div>

    <div class="mx-auto max-w-6xl px-6 md:px-10">
      <span class="font-display text-sm text-accent-soft">03 — AI-Ready</span>
      <h2
        class="mt-4 max-w-3xl font-display text-4xl font-light leading-tight md:text-5xl"
      >
        O ponto de partida para uma empresa usar IA de verdade.
      </h2>
      <p class="mt-5 max-w-2xl leading-relaxed text-paper/70">
        Antes de qualquer agente ou automação, é preciso ter o conhecimento da
        empresa organizado. AI-Ready é o processo padronizado que faz isso — de
        forma ágil e replicável: mapeia, estrutura e ativa esse conhecimento num
        assistente interno.
      </p>

      <!-- 3 passos -->
      <div
        class="mt-14 flex flex-col gap-4 md:flex-row md:items-stretch"
        data-steps
      >
        <div
          class="step relative flex-1 rounded-xl border border-paper/15 bg-paper/5 p-6"
          style="transition-delay: 0ms"
        >
          <img
            src="/images/ai-ready/mapear.webp"
            alt=""
            aria-hidden="true"
            width="128"
            height="128"
            loading="lazy"
            class="pointer-events-none absolute right-3 top-3 h-20 w-auto"
            style="image-rendering: pixelated;"
          />
          <div class="flex items-center gap-3">
            <span class="grid h-10 w-10 place-items-center rounded-full border border-accent-soft/40 text-accent-soft">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7" /><path d="m21 21-4.3-4.3" /></svg>
            </span>
            <span class="text-xs uppercase tracking-wider text-paper/50">
              Passo 1
            </span>
          </div>
          <h3 class="mt-4 font-display text-xl">Mapear</h3>
          <p class="mt-2 text-sm leading-relaxed text-paper/70">
            Levantamento do conhecimento espalhado: planilhas, e-mails,
            documentos e sistemas.
          </p>
        </div>

        <div class="hidden items-center self-center text-accent-soft md:flex" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6" /></svg>
        </div>

        <div
          class="step relative flex-1 rounded-xl border border-paper/15 bg-paper/5 p-6"
          style="transition-delay: 120ms"
        >
          <img
            src="/images/ai-ready/estruturar.webp"
            alt=""
            aria-hidden="true"
            width="128"
            height="128"
            loading="lazy"
            class="pointer-events-none absolute right-3 top-3 h-20 w-auto"
            style="image-rendering: pixelated;"
          />
          <div class="flex items-center gap-3">
            <span class="grid h-10 w-10 place-items-center rounded-full border border-accent-soft/40 text-accent-soft">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="8" ry="3" /><path d="M4 5v6c0 1.7 3.6 3 8 3s8-1.3 8-3V5" /><path d="M4 11v6c0 1.7 3.6 3 8 3s8-1.3 8-3v-6" /></svg>
            </span>
            <span class="text-xs uppercase tracking-wider text-paper/50">
              Passo 2
            </span>
          </div>
          <h3 class="mt-4 font-display text-xl">Estruturar</h3>
          <p class="mt-2 text-sm leading-relaxed text-paper/70">
            Organização e padronização numa base limpa, confiável e pesquisável.
          </p>
        </div>

        <div class="hidden items-center self-center text-accent-soft md:flex" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6" /></svg>
        </div>

        <div
          class="step relative flex-1 rounded-xl border border-paper/15 bg-paper/5 p-6"
          style="transition-delay: 240ms"
        >
          <img
            src="/images/ai-ready/oraculo.webp"
            alt=""
            aria-hidden="true"
            width="128"
            height="128"
            loading="lazy"
            class="pointer-events-none absolute right-3 top-3 h-20 w-auto"
            style="image-rendering: pixelated;"
          />
          <div class="flex items-center gap-3">
            <span class="grid h-10 w-10 place-items-center rounded-full border border-accent-soft/40 text-accent-soft">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /><path d="M12 7v4M10 9h4" /></svg>
            </span>
            <span class="text-xs uppercase tracking-wider text-paper/50">
              Passo 3
            </span>
          </div>
          <h3 class="mt-4 font-display text-xl">Oráculo</h3>
          <p class="mt-2 text-sm leading-relaxed text-paper/70">
            Um agente que responde sobre a empresa a partir dessa base de
            conhecimento.
          </p>
        </div>
      </div>

      <!-- Benefícios -->
      <div class="mt-14">
        <p class="mb-6 text-xs uppercase tracking-[0.2em] text-accent-soft">
          O que muda
        </p>
        <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {
            [
              "Decisões baseadas no que a empresa já sabe.",
              "Conhecimento que não se perde com a saída de pessoas.",
              "Onboarding de novos times mais rápido.",
              "Base pronta para escalar IA — automações e agentes.",
            ].map((b) => (
              <li class="rounded-lg border border-paper/15 p-4 text-sm leading-relaxed text-paper/80">
                {b}
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Linha discreta -->
      <p class="mt-12 text-sm text-paper/60">
        Faz sentido para a sua empresa?{" "}
        <a
          href="#contato"
          class="text-paper underline decoration-paper/30 underline-offset-4 transition-colors hover:decoration-paper"
        >
          Vamos conversar
        </a>.
      </p>
    </div>
  </section>

  <!-- ── Um pouco mais sobre mim (carrossel) ─────────────────── -->
  <section id="mais-sobre" class="mx-auto max-w-6xl px-6 py-20 md:px-10 md:py-28">
    <div class="mb-8 flex items-baseline justify-between border-b border-line pb-6">
      <h2 class="font-display text-3xl md:text-4xl">Um pouco mais sobre mim</h2>
      <span class="font-display text-sm text-accent">Fora do código</span>
    </div>

    <div
      class="carousel group relative overflow-hidden rounded-lg border border-line bg-paper-deep"
      data-carousel
      aria-roledescription="carrossel"
      aria-label="Um pouco mais sobre mim"
    >
      <!-- Trilho -->
      <div class="carousel-track flex aspect-[16/9] w-full" data-track>
        {
          aboutSlides.map((s, i) => (
            <figure
              class="relative w-full shrink-0"
              role="group"
              aria-roledescription="slide"
              aria-label={`${i + 1} de ${aboutSlides.length}`}
            >
              <img
                src={s.img}
                alt={s.title}
                width="1280"
                height="720"
                loading={i === 0 ? "eager" : "lazy"}
                class="h-full w-full object-cover"
                style="image-rendering: pixelated;"
              />
              <figcaption class="pointer-events-none absolute inset-x-0 bottom-0 bg-gradient-to-t from-ink/80 via-ink/30 to-transparent p-6 pt-16 md:p-8 md:pt-20">
                <span class="block font-display text-xl text-paper md:text-2xl">
                  {s.title}
                </span>
                {s.caption && (
                  <span class="mt-1 block max-w-xl text-sm text-paper/80">
                    {s.caption}
                  </span>
                )}
              </figcaption>
            </figure>
          ))
        }
      </div>

      <!-- Setas -->
      <button
        type="button"
        data-prev
        aria-label="Anterior"
        class="absolute left-3 top-1/2 grid h-10 w-10 -translate-y-1/2 place-items-center rounded-full bg-paper/80 text-ink opacity-0 backdrop-blur transition hover:bg-paper focus-visible:opacity-100 group-hover:opacity-100"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg>
      </button>
      <button
        type="button"
        data-next
        aria-label="Próximo"
        class="absolute right-3 top-1/2 grid h-10 w-10 -translate-y-1/2 place-items-center rounded-full bg-paper/80 text-ink opacity-0 backdrop-blur transition hover:bg-paper focus-visible:opacity-100 group-hover:opacity-100"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg>
      </button>

      <!-- Indicadores -->
      <div class="absolute bottom-4 right-4 flex gap-2" data-dots>
        {
          aboutSlides.map((_, i) => (
            <button
              type="button"
              data-dot={i}
              aria-label={`Ir para o slide ${i + 1}`}
              class="h-2 w-2 rounded-full bg-paper/50 transition-all hover:bg-paper"
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- Fontes ocultas do modal (uma por case) -->
  <div id="case-sources" hidden>
    {
      cases.map((c) => (
        <article data-modal={c.slug}>
