---
import Layout from "../layouts/Layout.astro";
import { amadeusProjects, personalProjects } from "../data/projects";
import { aboutSlides } from "../data/about";

const groups = [
  {
    label: "Amadeus AI",
    note: "Trabalho profissional — agentes, automações e dados em produção.",
    items: amadeusProjects,
  },
  {
    label: "Pessoal & Pesquisa",
    note: "Projetos próprios, apps e artigos acadêmicos.",
    items: personalProjects,
  },
];

const nav = [
  { label: "Sobre", href: "#sobre" },
  { label: "Trabalhos", href: "#trabalhos" },
  { label: "Contato", href: "#contato" },
];
---

<Layout>
  <!-- ── Hero full-bleed: Pouso Alegre animada (Pixel Lab) ───── -->
  <section class="relative isolate flex min-h-[90vh] flex-col overflow-hidden">
    <!-- Fundo: cidade animada + quadro estático p/ reduced-motion -->
    <img
      src="/images/pouso-alegre-hero.webp"
      alt="Pouso Alegre em pixel art — a praça da catedral, animada"
      width="384"
      height="216"
      class="hero-anim absolute inset-0 -z-20 h-full w-full object-cover"
      style="image-rendering: pixelated;"
    />
    <img
      src="/images/pouso-alegre-hero-static.png"
      alt="Pouso Alegre em pixel art — a praça da catedral"
      width="384"
      height="216"
      class="hero-static absolute inset-0 -z-20 h-full w-full object-cover"
      style="image-rendering: pixelated;"
    />
    <!-- Scrim de legibilidade -->
    <div
      class="absolute inset-0 -z-10 bg-gradient-to-t from-ink/90 via-ink/45 to-ink/25"
    >
    </div>

    <!-- Top bar sobreposta -->
    <header
      class="mx-auto flex w-full max-w-6xl items-center justify-between px-6 py-6 md:px-10"
    >
      <a
        href="#"
        class="font-display text-lg font-semibold tracking-tight text-paper"
      >
        Luca Stephan
      </a>
      <nav class="flex gap-6 text-sm text-paper/80">
        {
          nav.map((item) => (
            <a href={item.href} class="transition-colors hover:text-paper">
              {item.label}
            </a>
          ))
        }
      </nav>
    </header>

    <!-- Conteúdo do hero, ancorado embaixo -->
    <div
      class="mx-auto flex w-full max-w-6xl flex-1 flex-col justify-end px-6 pb-20 pt-16 md:px-10"
    >
      <p class="mb-5 font-sans text-sm uppercase tracking-[0.2em] text-paper/90">
        AI Engineer · Automações · Pouso Alegre, BR
      </p>
      <h1
        class="max-w-3xl font-display text-5xl font-light leading-[1.05] tracking-tight text-paper md:text-7xl"
      >
        Construo <em class="italic text-accent-soft">sistemas de IA</em> e
        <em class="italic">automações</em> sob medida — do dado cru ao produto.
      </h1>
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="#trabalhos"
          class="rounded-full bg-paper px-6 py-3 text-sm text-ink transition-transform hover:-translate-y-0.5"
        >
          Ver trabalhos
        </a>
        <a
          href="#contato"
          class="rounded-full border border-paper/40 px-6 py-3 text-sm text-paper transition-colors hover:bg-paper/10"
        >
          Entrar em contato
        </a>
      </div>
    </div>
  </section>

  <!-- ── Sobre ───────────────────────────────────────────────── -->
  <section id="sobre" class="border-t border-line bg-paper-deep/40 py-20 md:py-28">
    <div class="mx-auto grid max-w-6xl gap-10 px-6 md:grid-cols-12 md:px-10">
      <div class="md:col-span-4">
        <span class="font-display text-sm text-accent">01 — Sobre</span>
        <img
          src="/images/wizard-luca.webp"
          alt="Luca como um mago pixel art, meditando"
          width="256"
          height="256"
          loading="lazy"
          class="mt-2 w-80 md:-ml-20 md:-mt-4 md:w-[140%] md:max-w-none"
          style="image-rendering: pixelated;"
        />
      </div>
      <div class="md:col-span-8">
        <p class="font-display text-2xl font-light leading-snug md:text-3xl">
          Venho da administração de empresas — FGV EAESP e HEC Paris — e virei
          engenheiro por conta própria. Construo sistemas de IA, agentes e
          automações sob medida: do dado cru ao produto que alguém usa.
        </p>
        <p class="mt-6 max-w-2xl leading-relaxed text-muted">
          Trabalho como generalista — domino negócio e código, então conduzo um
          projeto complexo da concepção à entrega ponta a ponta, sozinho. Na
          prática, isso vira soluções altamente personalizadas, entregues em
          prazos curtos e sem fricção de repasse. Em paralelo, curso pós em
          Machine Learning Engineering, consolidando a base técnica desse
          trabalho.
        </p>

        <div class="mt-10 grid gap-8 border-t border-line pt-8 sm:grid-cols-2">
          <div>
            <h3 class="mb-4 text-xs uppercase tracking-[0.2em] text-accent">
              Formação
            </h3>
            <ul class="space-y-4 text-sm">
              <li>
                <span class="block font-medium">
                  Pós · Machine Learning Engineering
                </span>
                <span class="text-muted">Em andamento</span>
              </li>
              <li>
                <span class="block font-medium">HEC Paris</span>
                <span class="text-muted">
                  Bachelor of Business Administration (BBA) · 2023–
                </span>
              </li>
              <li>
                <span class="block font-medium">FGV EAESP</span>
                <span class="text-muted">
                  Administração de Empresas · São Paulo
                </span>
              </li>
            </ul>
          </div>
          <div>
            <h3 class="mb-4 text-xs uppercase tracking-[0.2em] text-accent">
              Reconhecimentos
            </h3>
            <ul class="space-y-4 text-sm">
              <li>
                <span class="block font-medium">
                  Quadro de Honra · FGV EAESP
                </span>
                <span class="text-muted">
                  Entre os 10 melhores alunos do semestre — 3º lugar (2020.2) e
                  9º lugar (2021.2)
                </span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Um pouco mais sobre mim (carrossel) ─────────────────── -->
  <section id="mais-sobre" class="mx-auto max-w-6xl px-6 py-20 md:px-10 md:py-28">
    <div class="mb-8 flex items-baseline justify-between border-b border-line pb-6">
      <h2 class="font-display text-3xl md:text-4xl">Um pouco mais sobre mim</h2>
      <span class="font-display text-sm text-accent">Fora do código</span>
    </div>

    <div
      class="carousel group relative overflow-hidden rounded-lg border border-line bg-paper-deep"
      data-carousel
      aria-roledescription="carrossel"
      aria-label="Um pouco mais sobre mim"
    >
      <!-- Trilho -->
      <div class="carousel-track flex aspect-[16/9] w-full" data-track>
        {
          aboutSlides.map((s, i) => (
            <figure
              class="relative w-full shrink-0"
              role="group"
              aria-roledescription="slide"
              aria-label={`${i + 1} de ${aboutSlides.length}`}
            >
              <img
                src={s.img}
                alt={s.title}
                width="1280"
                height="720"
                loading={i === 0 ? "eager" : "lazy"}
                class="h-full w-full object-cover"
                style="image-rendering: pixelated;"
              />
              <figcaption class="pointer-events-none absolute inset-x-0 bottom-0 bg-gradient-to-t from-ink/80 via-ink/30 to-transparent p-6 pt-16 md:p-8 md:pt-20">
                <span class="block font-display text-xl text-paper md:text-2xl">
                  {s.title}
                </span>
                {s.caption && (
                  <span class="mt-1 block max-w-xl text-sm text-paper/80">
                    {s.caption}
                  </span>
                )}
              </figcaption>
            </figure>
          ))
        }
      </div>

      <!-- Setas -->
      <button
        type="button"
        data-prev
        aria-label="Anterior"
        class="absolute left-3 top-1/2 grid h-10 w-10 -translate-y-1/2 place-items-center rounded-full bg-paper/80 text-ink opacity-0 backdrop-blur transition hover:bg-paper focus-visible:opacity-100 group-hover:opacity-100"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg>
      </button>
      <button
        type="button"
        data-next
        aria-label="Próximo"
        class="absolute right-3 top-1/2 grid h-10 w-10 -translate-y-1/2 place-items-center rounded-full bg-paper/80 text-ink opacity-0 backdrop-blur transition hover:bg-paper focus-visible:opacity-100 group-hover:opacity-100"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg>
      </button>

      <!-- Indicadores -->
      <div class="absolute bottom-4 right-4 flex gap-2" data-dots>
        {
          aboutSlides.map((_, i) => (
            <button
              type="button"
              data-dot={i}
              aria-label={`Ir para o slide ${i + 1}`}
              class="h-2 w-2 rounded-full bg-paper/50 transition-all hover:bg-paper"
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── Trabalhos ───────────────────────────────────────────── -->
  <section id="trabalhos" class="mx-auto max-w-6xl px-6 py-20 md:px-10 md:py-28">
    <div
      class="mb-12 flex items-baseline justify-between border-b border-line pb-6"
    >
      <h2 class="font-display text-3xl font-light md:text-4xl">
        Trabalhos selecionados
      </h2>
      <span class="font-display text-sm text-accent">02 — Trabalhos</span>
    </div>

    {
      groups.map((g, gi) => {
        // numeração de sumário contínua entre os grupos
        const offset = groups
          .slice(0, gi)
          .reduce((n, prev) => n + prev.items.length, 0);
        return (
          <div class={gi > 0 ? "mt-20" : ""}>
            <div class="mb-6 flex flex-wrap items-baseline justify-between gap-2">
              <h3 class="font-display text-xl italic text-accent">{g.label}</h3>
              <p class="text-sm text-muted">{g.note}</p>
            </div>
            <ul class="divide-y divide-line border-t border-line">
              {g.items.map((p, i) => (
                <li>
                  <a
                    href={p.href ?? "#"}
                    class="group grid gap-4 py-8 transition-colors hover:bg-paper-deep/40 md:grid-cols-12 md:gap-6 md:px-4"
                  >
                    <div class="flex items-baseline gap-4 md:col-span-1">
                      <span class="font-display text-sm text-muted">
                        {String(offset + i + 1).padStart(2, "0")}
                      </span>
                    </div>
                    <div class="md:col-span-7">
                      <h4 class="font-display text-2xl font-light tracking-tight transition-colors group-hover:text-accent md:text-3xl">
                        {p.title}
                      </h4>
                      <p class="mt-2 max-w-xl leading-relaxed text-muted">
                        {p.blurb}
                      </p>
                      <div class="mt-3 flex flex-wrap gap-2">
                        {p.tags.map((t) => (
                          <span class="rounded-full border border-line px-3 py-1 text-xs text-muted">
                            {t}
                          </span>
                        ))}
                      </div>
                    </div>
                    <div class="text-sm text-muted md:col-span-4 md:text-right">
                      <span class="block">{p.kind}</span>
                      <span class="block">{p.year}</span>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        );
      })
    }
  </section>

  <!-- ── Contato ─────────────────────────────────────────────── -->
  <section id="contato" class="border-t border-line bg-ink py-20 text-paper md:py-28">
    <div class="mx-auto max-w-6xl px-6 md:px-10">
      <span class="font-display text-sm text-paper/60">03 — Contato</span>
      <h2
        class="mt-4 max-w-2xl font-display text-4xl font-light leading-tight md:text-6xl"
      >
        Vamos construir algo juntos?
      </h2>
      <div class="mt-10 flex flex-wrap gap-6 text-lg">
        <a
          href="mailto:lucastephan8@gmail.com"
          class="underline decoration-paper/30 underline-offset-8 transition-colors hover:decoration-paper"
        >
          lucastephan8@gmail.com
        </a>
        <a
          href="https://github.com/lucastephan15"
          class="underline decoration-paper/30 underline-offset-8 transition-colors hover:decoration-paper"
        >
          GitHub
        </a>
      </div>
      <p class="mt-16 text-sm text-paper/50">
        © {new Date().getFullYear()} Luca Stephan — feito com Astro.
      </p>
    </div>
  </section>
</Layout>

<script>
  // Carrossel "Um pouco mais sobre mim" — leve, sem dependências.
  function initCarousel(root: HTMLElement) {
    const track = root.querySelector<HTMLElement>("[data-track]");
    const slides = track ? Array.from(track.children) as HTMLElement[] : [];
    const dots = Array.from(root.querySelectorAll<HTMLElement>("[data-dot]"));
    const prev = root.querySelector<HTMLElement>("[data-prev]");
    const next = root.querySelector<HTMLElement>("[data-next]");
    if (!track || slides.length === 0) return;

    let index = 0;
    const total = slides.length;
    const interval = Number(root.dataset.interval) || 0;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let timer: number | undefined;

    function render() {
      track!.style.transform = `translateX(-${index * 100}%)`;
      dots.forEach((d, i) => {
        const on = i === index;
        d.style.width = on ? "1.5rem" : "0.5rem";
        d.classList.toggle("bg-paper", on);
        d.classList.toggle("bg-paper/50", !on);
        d.setAttribute("aria-current", on ? "true" : "false");
      });
    }
    function go(i: number) {
      index = (i + total) % total;
      render();
    }
    function play() {
      if (!interval || reduce) return;
      stop();
      timer = window.setInterval(() => go(index + 1), interval);
    }
    function stop() {
      if (timer) window.clearInterval(timer);
    }

    next?.addEventListener("click", () => { go(index + 1); play(); });
    prev?.addEventListener("click", () => { go(index - 1); play(); });
    dots.forEach((d, i) => d.addEventListener("click", () => { go(i); play(); }));

    root.addEventListener("mouseenter", stop);
    root.addEventListener("mouseleave", play);
    root.addEventListener("focusin", stop);
    root.addEventListener("focusout", play);

    // Teclado (quando o carrossel está em foco)
    root.tabIndex = 0;
    root.addEventListener("keydown", (e) => {
      if (e.key === "ArrowRight") { go(index + 1); play(); }
      if (e.key === "ArrowLeft") { go(index - 1); play(); }
    });

    // Swipe / arraste
    let startX = 0, dragging = false;
    root.addEventListener("pointerdown", (e) => { dragging = true; startX = e.clientX; stop(); });
    root.addEventListener("pointerup", (e) => {
      if (!dragging) return;
      dragging = false;
      const dx = e.clientX - startX;
      if (Math.abs(dx) > 40) go(index + (dx < 0 ? 1 : -1));
      play();
    });

    // Transição suave (respeitando reduced-motion)
    track.style.transition = reduce ? "none" : "transform 500ms cubic-bezier(0.22,1,0.36,1)";
    render();
    play();
  }

  document.querySelectorAll<HTMLElement>("[data-carousel]").forEach(initCarousel);
</script>
